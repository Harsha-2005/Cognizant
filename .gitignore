# =============================================================
#  .gitignore — Cognizant Java Training Project
#  Covers: Java, IntelliJ IDEA, Maven, Gradle, Windows, macOS
# =============================================================


# ─────────────────────────────────────────
# Java Compiled Output
# ─────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar

# Java Annotation Processor output
generated/
generated-sources/

# ─────────────────────────────────────────
# IntelliJ IDEA
# ─────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# IntelliJ workspace and local settings (should not be shared)
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries/
.idea/shelf/
.idea/aws.xml
.idea/httpRequests/
.idea/dataSources/
.idea/dataSources.local.xml
.idea/dynamic.xml
.idea/uiDesigner.xml
.idea/gradle.xml
.idea/libraries/
.idea/modules.xml
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/inspectionProfiles/
.idea/runConfigurations/
.idea/vcs.xml
.idea/misc.xml

# ─────────────────────────────────────────
# Eclipse
# ─────────────────────────────────────────
.classpath
.project
.settings/
bin/
*.launch

# ─────────────────────────────────────────
# Maven
# ─────────────────────────────────────────
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ─────────────────────────────────────────
# Gradle
# ─────────────────────────────────────────
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/
gradle-app.setting
!gradle-wrapper.jar
.gradletasknamecache

# ─────────────────────────────────────────
# Logs & Temp Files
# ─────────────────────────────────────────
*.log
*.tmp
*.temp
*.swp
*.bak
*.orig
logs/
log/
temp/
tmp/

# ─────────────────────────────────────────
# Windows System Files
# ─────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# ─────────────────────────────────────────
# macOS System Files
# ─────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ─────────────────────────────────────────
# VS Code
# ─────────────────────────────────────────
.vscode/
*.code-workspace

# ─────────────────────────────────────────
# Office / Document Temp Files
# ─────────────────────────────────────────
~$*.docx
~$*.xlsx
~$*.pptx
*.~docx

# ─────────────────────────────────────────
# Project-Specific Ignores
# ─────────────────────────────────────────
# Compiled output directory (IntelliJ default)
out/

# Do NOT ignore source .docx task files (keep them tracked)
# *.docx  ← intentionally NOT listed here
